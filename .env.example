# Copy this to ".env" in the project root (same folder as manage.py) and fill
# in real values. On PythonAnywhere, create this file via the Files tab or a
# Bash console: nano .env

# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=replace-with-a-long-random-secret

DEBUG=False

# Comma-separated. Must match the domain you access the API from.
# PythonAnywhere free tier gives you: yourname.pythonanywhere.com
ALLOWED_HOSTS=yourname.pythonanywhere.com

# MySQL — on PythonAnywhere find these under the "Databases" tab
DB_NAME=yourname$default
DB_USER=yourname
DB_PASSWORD=your-db-password
DB_HOST=yourname.mysql.pythonanywhere-services.com
DB_PORT=3306

# Comma-separated list of frontend origins allowed to call this API.
# Add your Cloudflare Pages URL here once deployed, e.g.
# https://tanus-collection.pages.dev
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
